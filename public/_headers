# Immutable assets (hash-based)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Semi-static assets
/favicon.*
  Cache-Control: public, max-age=86400

/brand/*
  Cache-Control: public, max-age=86400
/social/*
  Cache-Control: public, max-age=86400
/about/*
  Cache-Control: public, max-age=86400
/gallery/*
  Cache-Control: public, max-age=86400

# Admin — never cache
/admin
  Cache-Control: private, no-store
/admin/*
  Cache-Control: private, no-store

# HTML pages — no edge cache (freshness via Worker Cache API)
/*
  Cache-Control: public, max-age=0, s-maxage=0
