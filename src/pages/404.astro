---
import Layout from "@/layouts/Layout.astro";
import { SearchBar } from "@/components/ui/SearchBar";

const staticSearchProps = { className: "max-w-md mx-auto", inputClassName: "bg-hype/10 border-hype/20 text-foreground placeholder:text-foreground/30" };
---

<Layout title="404 - Página no encontrada" description="404 - Página no encontrada">
  <main class="flex min-h-[calc(100dvh-4rem)] flex-col items-center justify-center px-4 text-center relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 z-0">
      <div class="absolute left-1/2 top-1/3 size-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-hype/5 blur-[160px]" />
    </div>

    <div class="relative z-10 space-y-8 max-w-lg">
      <div class="space-y-3">
        <h1 class="text-9xl font-black leading-none tracking-tighter text-hype select-none">
          404
        </h1>
        <p class="text-xl text-muted-foreground sm:text-2xl">
          Esta página no existe o fue movida.
        </p>
      </div>

      <div class="flex flex-col items-center gap-3">
        <a
          href="/catalogo"
          class="inline-flex h-11 items-center gap-1.5 rounded-md bg-hype px-8 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0"><path d="m15 18-6-6 6-6"/></svg>
          Ir al catálogo
        </a>

        <a
          href="/"
          class="font-1 text-[11px] tracking-[0.2em] uppercase text-muted-foreground hover:text-hype transition-colors"
        >
          Volver al inicio
        </a>
      </div>

      <div class="pt-4 border-t border-border/50">
        <p class="font-1 text-[10px] tracking-[0.2em] uppercase text-muted-foreground mb-3">
          O buscá lo que necesitás
        </p>
        <SearchBar {...staticSearchProps} client:load />
      </div>
    </div>
  </main>
</Layout>
